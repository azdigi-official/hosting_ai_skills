# Sao chép file này thành .env và điền thông tin thật.
#   cp .env.example .env
# .env đã được .gitignore — KHÔNG commit token lên git.

# Hostname hoặc IP của máy chủ cPanel (không kèm https:// hay cổng)
CPANEL_HOST=server.example.com

# Tên đăng nhập tài khoản cPanel (chủ gói hosting)
CPANEL_USER=myuser

# API token tạo tại: cPanel > Security > Manage API Tokens
# Token mang đúng quyền của tài khoản hosting, KHÔNG phải root/WHM.
CPANEL_API_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Cổng cPanel (mặc định 2083 cho HTTPS). 2082 nếu dùng HTTP.
CPANEL_PORT=2083
CPANEL_SCHEME=https

# Tùy chọn:
# CPANEL_INSECURE=1   # bỏ qua kiểm tra TLS khi server dùng self-signed cert
# CPANEL_TIMEOUT=60   # timeout mỗi request (giây)
# CPANEL_DEBUG=1      # in log debug
